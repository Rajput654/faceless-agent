# FACELESS AGENT - Environment Variables
# Copy this to .env for local testing
# For GitHub: Add each as a GitHub Secret

# GROQ API (Free: console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GOOGLE GEMINI (Free fallback: aistudio.google.com)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PEXELS API (Free: pexels.com/api)
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PIXABAY API (Free: pixabay.com/api)
PIXABAY_API_KEY=xxxxxxxx-xxxxxxxxxxxxxxxx

# REDDIT API (Free: reddit.com/prefs/apps)
REDDIT_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REDDIT_USER_AGENT=faceless-agent/1.0

# YOUTUBE API (Free: console.cloud.google.com)
YOUTUBE_CLIENT_ID_A=xxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET_A=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_REFRESH_TOKEN_A=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

YOUTUBE_CLIENT_ID_B=xxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET_B=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_REFRESH_TOKEN_B=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SUPABASE (Free: supabase.com)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LANGFUSE (Free: langfuse.com)
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# CONFIG
NICHE=motivation
DAILY_VIDEO_COUNT=10
